# Copy to .env and fill in your values.
# Never commit .env to version control.

# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER=openai                        # "openai" | "groq" | "llama"

# OpenAI-compatible backend (Ollama, LM Studio, vLLM, …)
LLM_BASE_URL=http://localhost:11434/v1     # Ollama default; change for LM Studio (port 1234)
LLM_MODEL_NAME=llama3                      # must match the name exposed by the server

# Groq cloud (used only when LLM_PROVIDER=groq)
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# Legacy local GGUF (used only when LLM_PROVIDER=llama)
LLM_MODEL_PATH=models/llama-3.gguf

LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=service_catalogue
CHROMA_N_RESULTS=3

# ── Persistence ───────────────────────────────────────────────────────────────
SQLITE_DB_PATH=data/checkpoints.db

# ── Routing ───────────────────────────────────────────────────────────────────
MAX_RETRY_COUNT=2
MAPPER_MIN_RESULTS=1

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
LOG_LEVEL=INFO

# ── Security ──────────────────────────────────────────────────────────────────
PII_MASK_TOKEN=[REDACTED]

# ── Catalogue upload (B1) ─────────────────────────────────────────────────────
UPLOAD_DIR=uploads                         # base dir for uploaded catalogues (tenant-scoped subdirs)
UPLOAD_MAX_BYTES=10485760                  # 10 MB
