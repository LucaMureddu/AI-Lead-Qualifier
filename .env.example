# .env.example (Sviluppo Locale V2)

# ── API & Sicurezza (JWT RS256) ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
LOG_LEVEL=DEBUG
PII_MASK_TOKEN=[REDACTED]

# Path locali alle chiavi per lo sviluppo (generate con openssl)
JWT_PUBLIC_KEY_PATH=backend/keys/public.pem
JWT_PRIVATE_KEY_PATH=backend/keys/private.pem

# ── Persistenza (Postgres & Redis) ────────────────────────────────────────────
DATABASE_DSN=postgresql+asyncpg://app:password@localhost/ai_lead_qualifier
REDIS_DSN=redis://localhost:6379

# ── Modelli Locali (Ollama) ───────────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=qwen2.5:14b
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
PGVECTOR_EMBEDDING_DIM=768

# ── Parametri di Business (Routing & RAG) ─────────────────────────────────────
MAX_RETRY_COUNT=2
PGVECTOR_N_RESULTS=3
MAPPER_MAX_DISTANCE=0.80
EVALUATOR_THRESHOLD=0.55
INGESTION_CHUNK_SIZE=10
ARQ_MAX_JOBS=1

DOCKER_SOCK=/Users/lucamureddu/.docker/run/docker.sock