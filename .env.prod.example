# .env.prod.example
# ─────────────────────────────────────────────────────────────────────────────
# Bozza del file di configurazione produzione.
#
# USO:
#   cp .env.prod.example .env.prod
#   nano .env.prod            ← sostituire TUTTI i placeholder <...>
#   chmod 600 .env.prod       ← leggibile solo dal proprietario
#
# SICUREZZA:
#   • .env.prod NON va mai committato su git (già in .gitignore).
#   • Usare `openssl rand -hex 32` per generare password sicure.
#   • Le chiavi RSA vanno generate separatamente (vedi §JWT più sotto).
#
# MIGRAZIONE DATA CENTER FUTURA:
#   Quando Postgres e Redis saranno su server dedicati, aggiornare
#   DATABASE_DSN e REDIS_DSN con i nuovi DSN e rimuovere POSTGRES_* e
#   REDIS_PASSWORD da questo file (non servono più a docker-compose.prod.yml).
# ─────────────────────────────────────────────────────────────────────────────


# ── Versione applicazione (tag immagine Docker) ───────────────────────────────
APP_VERSION=1.0.0


# ── Domini pubblici (Traefik + Let's Encrypt) ─────────────────────────────────
# Il certificato SSL viene emesso automaticamente per questi domini.
# Devono puntare all'IP del server prima del primo deploy.
APP_DOMAIN=app.tuaazienda.com
API_DOMAIN=api.tuaazienda.com
ACME_EMAIL=devops@tuaazienda.com


# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=ai_lead_qualifier
POSTGRES_USER=app
# Generare con: openssl rand -hex 32
POSTGRES_PASSWORD=<CAMBIA_CON_PASSWORD_SICURA>

# DSN completo usato dal backend e dal worker.
# In produzione viene composto dinamicamente in docker-compose.prod.yml
# dalle variabili POSTGRES_* — lasciare questo campo come riferimento
# per eventuali script manuali (alembic upgrade, seed_db.py).
DATABASE_DSN=postgresql://app:<POSTGRES_PASSWORD>@postgres/ai_lead_qualifier


# ── Redis ─────────────────────────────────────────────────────────────────────
# Generare con: openssl rand -hex 32
REDIS_PASSWORD=<CAMBIA_CON_PASSWORD_SICURA>

# DSN con autenticazione (composto in docker-compose.prod.yml).
REDIS_DSN=redis://:<REDIS_PASSWORD>@redis:6379


# ── JWT RS256 ─────────────────────────────────────────────────────────────────
# Percorso locale delle chiavi RSA (montato read-only nel container).
# Generare le chiavi con:
#   mkdir -p ./keys
#   openssl genrsa -out ./keys/private.pem 2048
#   openssl rsa -in ./keys/private.pem -pubout -out ./keys/public.pem
#   chmod 600 ./keys/private.pem
JWT_KEYS_PATH=./keys
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem


# ── Ollama (LLM + Embedding sul host) ────────────────────────────────────────
# Ollama NON è containerizzato: gira nativamente sul host con accesso GPU.
# host.docker.internal risolve l'IP del host dalla rete Docker.
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_PROVIDER=openai
LLM_MODEL_NAME=qwen2.5:14b

EMBEDDING_BASE_URL=http://host.docker.internal:11434
EMBEDDING_MODEL=nomic-embed-text
# Deve coincidere con la dimensione dell'embedding_model:
# nomic-embed-text → 768 | mxbai-embed-large → 1024
PGVECTOR_EMBEDDING_DIM=768


# ── ARQ Worker — concorrenza GPU ─────────────────────────────────────────────
# Su GPU condivisa con LLM 14B: tenere a 1 per evitare VRAM OOM.
# Data center futuro (GPU dedicata): aumentare a 2-3 con cautela.
ARQ_MAX_JOBS=1
ARQ_JOB_TIMEOUT=300
ARQ_KEEP_RESULT=86400


# ── Parametri applicativi ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
PGVECTOR_N_RESULTS=3
MAPPER_MAX_DISTANCE=0.80
EVALUATOR_THRESHOLD=0.55
MAX_RETRY_COUNT=2
INGESTION_CHUNK_SIZE=5

DELIVERY_MAX_ATTEMPTS=3
DELIVERY_TIMEOUT_SECONDS=5.0

DOCKER_SOCK=/Users/lucamureddu/.docker/run/docker.sock